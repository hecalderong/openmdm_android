# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=mdm_user
DATABASE_PASSWORD=mdm_password
DATABASE_NAME=openmdm_android

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Application
PORT=3000
NODE_ENV=development

# File Storage
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600

# CORS
CORS_ORIGIN=*
